# ===========================================================
# Business Central Integration Suite - 範本環境變數
# 複製為 .env 後填入實際值
# ===========================================================

# --- API 基本設定 ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
SECRET_KEY=change-this-in-production-please

# --- 資料庫設定 ---
# 預設使用 SQLite（零設定即可跑）
DATABASE_URL=sqlite:///./data/bcsuite.db
# 若要改 PostgreSQL（docker-compose 預設提供）：
# DATABASE_URL=postgresql+psycopg2://bcsuite:bcsuite@db:5432/bcsuite

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# --- 商業規則 ---
HIGH_RISK_THRESHOLD=100000

# --- Business Central 連線模式 ---
# mock = 用內建假連接器（預設，不需要真實 BC）
# real = 串接真實 BC API（需要 Entra ID App Registration）
BC_MODE=mock

# --- 真實 BC API 設定（BC_MODE=real 時才需要）---
BC_BASE_URL=https://api.businesscentral.dynamics.com/v2.0
BC_TENANT_ID=
BC_ENVIRONMENT=Production
BC_COMPANY_ID=
BC_CLIENT_ID=
BC_CLIENT_SECRET=
BC_API_PUBLISHER=xu323
BC_API_GROUP=integration
BC_API_VERSION=v1.0
